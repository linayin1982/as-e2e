{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
//    "outDir": "../../lib/bar",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@utils/*.js": ["src/utils/*.ts"],
      "@pages/*": ["src/pages/*"],
      "@pages/*.js": ["src/pages/*.ts"],
      "@support/*": ["src/support/*"],
      "@support/*.js": ["src/support/*.ts"],
      "@bdd/*": ["src/bdd/*"],
      "@bdd/*.js": ["src/bdd/*.ts"]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "references": [
    { "path": "../call-center-integration-test" }
  ]
}

